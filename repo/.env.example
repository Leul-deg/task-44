# Copy to .env and replace every value. Docker Compose reads .env automatically
# and uses it to override the labelled placeholder defaults that ship in
# docker-compose.yml (INSECURE_DEFAULT_… / INSECURE_32B_DEFAULT_…). Those
# placeholders only exist so that a fresh `git clone && docker compose up`
# works on cloud CI; they are NOT safe for any shared environment.
MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
DB_PASSWORD=replace-with-a-strong-database-password
# AES-256-GCM: exactly 32 ASCII characters OR Base64 that decodes to exactly 32 bytes (generate your own).
AES_SECRET_KEY=yourExactly32CharSecretKeyHere!!
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-bootstrap-password
FILE_STORAGE_PATH=./uploads
BACKUP_PATH=./backups
COOKIE_SECURE=false
