# Copy to .env and replace every value. Docker Compose reads this file automatically.
# Required for docker compose up (no defaults in docker-compose.yml):
MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
DB_PASSWORD=replace-with-a-strong-database-password
# AES-256-GCM: exactly 32 ASCII characters OR Base64 that decodes to exactly 32 bytes (generate your own).
AES_SECRET_KEY=yourExactly32CharSecretKeyHere!!
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-bootstrap-password
FILE_STORAGE_PATH=./uploads
BACKUP_PATH=./backups
COOKIE_SECURE=false
